rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: uid
    // Fields: uid, email, displayName, photoURL
    //
    // Collection: lists
    // Document ID: auto-generated
    // Fields: title, description, category, isPublic, ownerId, ownerEmail, sharedWith (array of uids), createdAt
    //
    // Collection: lists/{listId}/items
    // Document ID: auto-generated
    // Fields: text, isChecked, listId, createdAt
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isListOwner(listData) {
      return isAuthenticated() && request.auth.uid == listData.ownerId;
    }

    function isListShared(listData) {
      return isAuthenticated() && (request.auth.uid in listData.sharedWith || request.auth.token.email in listData.sharedWith);
    }

    function canReadList(listData) {
      return listData.isPublic == true || isListOwner(listData) || isListShared(listData);
    }

    function canWriteList(listData) {
      return isListOwner(listData) || isListShared(listData);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.uid is string && data.email is string;
    }

    function isValidList(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.ownerId is string &&
             data.isPublic is bool &&
             data.category in ['General', 'Trip', 'Ski', 'Children', 'Other'];
    }

    function isValidItem(data) {
      return data.text is string && data.text.size() > 0 && data.text.size() < 500 &&
             data.isChecked is bool &&
             data.listId is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read, write: if isOwner(uid) && (request.method == 'delete' || isValidUser(request.resource.data));
    }

    match /lists/{listId} {
      allow read: if canReadList(resource.data);
      allow create: if isAuthenticated() && isValidList(request.resource.data) && request.resource.data.ownerId == request.auth.uid;
      allow update: if canWriteList(resource.data) && isValidList(request.resource.data) && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isListOwner(resource.data);

      match /items/{itemId} {
        allow read: if canReadList(get(/databases/$(database)/documents/lists/$(listId)).data);
        allow write: if canWriteList(get(/databases/$(database)/documents/lists/$(listId)).data) && (request.method == 'delete' || isValidItem(request.resource.data));
      }
    }
    
    // Public lists query
    match /lists/{listId} {
       allow list: if resource.data.isPublic == true || (isAuthenticated() && (resource.data.ownerId == request.auth.uid || request.auth.uid in resource.data.sharedWith));
    }
  }
}
