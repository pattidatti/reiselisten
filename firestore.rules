rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isListOwner(listData) {
      return isAuthenticated() && request.auth.uid == listData.ownerId;
    }

    function isListShared(listData) {
      return isAuthenticated() && (request.auth.uid in listData.sharedWith || request.auth.token.email in listData.sharedWith);
    }

    function canReadList(listData) {
      return listData.isPublic == true || isListOwner(listData) || isListShared(listData);
    }

    function canWriteList(listData) {
      return isListOwner(listData) || isListShared(listData);
    }

    // ===============================================================
    // Users — public read, self write
    // ===============================================================
    match /users/{uid} {
      allow read: if true;
      allow create: if isOwner(uid)
        && request.resource.data.uid is string
        && request.resource.data.email is string;
      allow update: if isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.email == resource.data.email;
      allow delete: if false;
    }

    // ===============================================================
    // Usernames — uniqueness registry
    // ===============================================================
    match /usernames/{username} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // ===============================================================
    // Lists
    // ===============================================================
    match /lists/{listId} {
      allow read: if canReadList(resource.data);
      allow create: if isAuthenticated()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0;
      allow update: if canWriteList(resource.data)
        && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isListOwner(resource.data);

      match /items/{itemId} {
        allow read: if canReadList(get(/databases/$(database)/documents/lists/$(listId)).data);
        allow write: if canWriteList(get(/databases/$(database)/documents/lists/$(listId)).data);
      }
    }

    // Public lists query
    match /lists/{listId} {
      allow list: if resource.data.isPublic == true
        || (isAuthenticated() && (resource.data.ownerId == request.auth.uid || request.auth.uid in resource.data.sharedWith));
    }

    // ===============================================================
    // Share Tokens
    // ===============================================================
    match /shareTokens/{token} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated()
        && resource.data.createdBy == request.auth.uid;
      allow update: if false;
    }

    // ===============================================================
    // Follows
    // ===============================================================
    match /follows/{followId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.followerUid == request.auth.uid
        && followId == (request.auth.uid + '_' + request.resource.data.followedUid);
      allow delete: if isAuthenticated()
        && resource.data.followerUid == request.auth.uid;
      allow update: if false;
    }

    // ===============================================================
    // Stars
    // ===============================================================
    match /stars/{starId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid
        && starId == (request.auth.uid + '_' + request.resource.data.listId);
      allow delete: if isAuthenticated()
        && resource.data.uid == request.auth.uid;
      allow update: if false;
    }
  }
}
